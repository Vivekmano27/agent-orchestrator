# ============================================================
# Solo Dev Orchestrator — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================================

# General
NODE_ENV=development
PORT=3000

# ---- NestJS Core Service ----
CORE_SERVICE_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/core_db
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- NestJS API Gateway ----
GATEWAY_PORT=3000
CORE_SERVICE_URL=http://localhost:3001
AI_SERVICE_URL=http://localhost:8000

# ---- Python AI Service ----
AI_SERVICE_PORT=8000
AI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_db
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
DEFAULT_AI_MODEL=claude-sonnet-4-20250514
CELERY_BROKER_URL=redis://localhost:6379/1

# ---- React/Next.js Web ----
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ---- AWS (Production) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
CLOUDFRONT_DISTRIBUTION_ID=

# ---- SMTP (Email) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
